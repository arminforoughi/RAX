# RAX LiveKit + Gemini gaze agent — copy to .env.local and fill in real values
#
# LiveKit Cloud: https://cloud.livekit.io/projects → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional hardware overrides
# ROBOT_PORT=/dev/ttyACM0
# ROBOT_URDF=SO101/so101_new_calib.urdf
# GAZE_APPROACH=angled
# GAZE_DETECTOR=auto
# GAZE_STEREO=sgbm
